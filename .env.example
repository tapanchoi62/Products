# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=product_service
DB_SYNCHRONIZE=true
DB_LOGGING=true

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Swagger
SWAGGER_ENABLED=true
SWAGGER_TITLE=Product Service API
SWAGGER_DESCRIPTION=Product management microservice API documentation
SWAGGER_VERSION=1.0
SWAGGER_PATH=docs
